# PocketBase (homelab, public-facing via Traefik)
POCKETBASE_URL=https://mc-db.subliminal.gg

# Discord (bot token; bot must be in the channels listed in cron route)
DISCORD_BOT_TOKEN=

# RSI Spectrum (Evocati / PTU-tester account; required for MOTDs)
RSI_TOKEN=

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Twitch (creators feed live state)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Cron auth (homelab script passes ?secret=$CRON_SECRET on each cron URL)
CRON_SECRET=

# Google Analytics 4 — measurement ID for the sc-feed.subliminal.gg data stream
# (its own stream, NOT the subliminal.gg one). Loads gtag.js for all visitors when set.
NEXT_PUBLIC_GA_ID=

# --- Auth + owner RSI-token push (Phase 1) ---
# PocketBase superuser — server-side ONLY, used for the locked sc_feed_config collection.
# Same creds as subliminal.gg (shared PocketBase). Never expose to the client.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# NextAuth v5 — REUSES subliminal.gg's OAuth apps so accounts are shared across
# *.subliminal.gg. Each provider's app must whitelist the redirect URI
# https://sc-feed.subliminal.gg/api/auth/callback/<provider>.
AUTH_SECRET=
NEXTAUTH_URL=https://sc-feed.subliminal.gg
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# (TWITCH_CLIENT_ID / TWITCH_CLIENT_SECRET above are reused by the NextAuth Twitch provider.)

# Owner RSI-token push — bearer fallback for the browser extension when not signed in as
# owner. Long random string; the same value goes in the extension popup. Generate with:
#   openssl rand -hex 32
OWNER_PUSH_SECRET=
