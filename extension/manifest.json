{
  "manifest_version": 3,
  "name": "SC Feed Companion",
  "version": "0.2.4",
  "description": "RSI token sync + new-item badge/notifications + 'Send to SC Feed' for SC Feed. Owner tool.",
  "permissions": ["cookies", "storage", "alarms", "notifications", "contextMenus", "tabs"],
  "host_permissions": [
    "https://robertsspaceindustries.com/*",
    "https://*.robertsspaceindustries.com/*",
    "https://sc-feed.subliminal.gg/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "SC Feed Companion" }
}
